#!/usr/bin/env bash
# bin/autotune — Main CLI entry point for autotune

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
AUTOTUNE_HOME="${CLAUDE_PLUGIN_ROOT:-${AUTOTUNE_HOME:-$(dirname "$SCRIPT_DIR")}}"
source "$AUTOTUNE_HOME/lib/state.sh"

VERSION="0.1.0"

usage() {
  cat <<EOF
autotune v${VERSION} — Autonomous optimization loops for Claude Code

Usage: autotune <command> [options]

Commands:
  start [goal]          Launch the autotune agent in Claude Code
  stop                  Turn off autotune mode (preserves log)
  clear                 Delete autotune.jsonl and reset state
  dashboard [--watch]   Show experiment dashboard (--watch for live, --full for all)
  status                Show current autotune state
  explain               Explain current health, blockers, and next action
  repair                Resume in repair mode after repeated failures
  version               Show version

Examples:
  autotune start "optimize test speed"
  autotune dashboard --watch
  autotune explain
  autotune repair
EOF
}

cmd_start() {
  local goal="${1:-}"
  echo "Starting autotune agent..."
  if [[ -n "$goal" ]]; then
    claude --agent autotune -p "Set up autotune for: $goal"
  else
    claude --agent autotune
  fi
}

cmd_stop() {
  local workdir
  workdir=$(resolve_workdir ".")
  if is_autotune_active "$workdir"; then
    update_state_field "$workdir" "active" "false"
    update_state_field "$workdir" "health" '"paused"'
    echo "Autotune mode disabled. Session data preserved."
    echo "Resume with: autotune start"
  else
    echo "Autotune is not active."
  fi
}

cmd_clear() {
  local workdir
  workdir=$(resolve_workdir ".")
  local jsonl_path
  jsonl_path=$(get_jsonl_path "$workdir")
  local state_path
  state_path=$(get_state_path "$workdir")
  echo -n "This will delete autotune.jsonl and .autotune.state. Continue? [y/N] "
  read -r confirm
  if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
    echo "Cancelled."
    return
  fi
  rm -f "$jsonl_path" "$state_path"
  echo "Session data cleared."
}

cmd_dashboard() {
  bash "$AUTOTUNE_HOME/bin/dashboard.sh" "$@"
}

cmd_status() {
  local workdir
  workdir=$(resolve_workdir ".")
  local jsonl_path
  jsonl_path=$(get_jsonl_path "$workdir")
  local state_path
  state_path=$(get_state_path "$workdir")

  echo "autotune v${VERSION}"
  echo ""

  if [[ -f "$state_path" ]]; then
    local state
    state=$(cat "$state_path")
    local mode
    mode=$(STATE_JSON="$state" python3 - <<'PY'
import json
import os

print(json.loads(os.environ["STATE_JSON"]).get("active", False))
PY
)
    local op_mode
    op_mode=$(STATE_JSON="$state" python3 - <<'PY'
import json
import os

print(json.loads(os.environ["STATE_JSON"]).get("mode", "optimize"))
PY
)
    local health
    health=$(STATE_JSON="$state" python3 - <<'PY'
import json
import os

print(json.loads(os.environ["STATE_JSON"]).get("health", "running"))
PY
)
    local failures
    failures=$(STATE_JSON="$state" python3 - <<'PY'
import json
import os

print(json.loads(os.environ["STATE_JSON"]).get("crash_streak", 0))
PY
)
    local no_improvement
    no_improvement=$(STATE_JSON="$state" python3 - <<'PY'
import json
import os

print(json.loads(os.environ["STATE_JSON"]).get("no_improve", 0))
PY
)
    echo "Mode:       $([ "$mode" = "True" ] && echo "ACTIVE" || echo "inactive")"
    echo "Strategy:   $op_mode"
    echo "Health:     $health"
    echo "Failures:   $failures crash streak / $no_improvement no-improvement"
  else
    echo "Mode:       not initialized"
  fi

  echo ""
  if [[ -f "$jsonl_path" ]]; then
    local segment
    segment=$(get_current_segment "$jsonl_path")
    local total
    total=$(count_experiments "$jsonl_path" "$segment")
    echo "JSONL:      $jsonl_path"
    echo "Segment:    $segment"
    echo "Total runs: $total (current segment)"
  else
    echo "JSONL:      (no session file)"
  fi
}

cmd_explain() {
  local workdir
  workdir=$(resolve_workdir ".")
  local jsonl_path
  jsonl_path=$(get_jsonl_path "$workdir")
  local state_json
  state_json=$(read_state "$workdir")
  if [[ ! -f "$jsonl_path" ]]; then
    echo '{"error": "No session found."}'
    return 1
  fi
  local segment
  segment=$(get_current_segment "$jsonl_path")
  local config
  config=$(get_config_for_segment "$jsonl_path" "$segment")
  local direction
  direction=$(CONFIG_JSON="$config" python3 - <<'PY'
import json
import os

print(json.loads(os.environ["CONFIG_JSON"]).get("direction", "lower"))
PY
)
  local summary
  summary=$(segment_summary_json "$jsonl_path" "$segment" "$direction")
  python3 "$AUTOTUNE_HOME/lib/health.py" --explain --summary "$summary" --state "$state_json" --config "$config" | python3 - <<'PY'
import json
import sys

payload = json.load(sys.stdin)
print(f"Health:    {payload.get('health')}")
print(f"Mode:      {payload.get('mode')}")
print(f"Failure:   {payload.get('failure') or 'none'}")
print(f"Action:    {payload.get('suggested_next_action')}")
print(f"Reason:    {payload.get('reason') or 'n/a'}")
print(f"Baseline:  {payload.get('baseline')}")
print(f"Best:      {payload.get('best')}")
print(f"Last:      {payload.get('last_metric')} ({payload.get('last_status')})")
print(
    f"Streaks:   crash={payload.get('crash_streak')} "
    f"no_improve={payload.get('no_improve')} "
    f"keep={payload.get('keep_streak')}"
)
PY
}

cmd_repair() {
  local workdir
  workdir=$(resolve_workdir ".")
  local patch
  patch='{"active": true, "mode": "repair", "health": "healing", "recovery": "manual_repair", "reason": "operator requested repair mode"}'
  set_state_fields "$workdir" "$patch"
  echo "Autotune set to repair mode. Resume with: claude --agent autotune"
}

COMMAND="${1:-}"
shift || true

case "$COMMAND" in
  start) cmd_start "$@" ;;
  stop) cmd_stop ;;
  clear) cmd_clear ;;
  dashboard) cmd_dashboard "$@" ;;
  status) cmd_status ;;
  explain) cmd_explain ;;
  repair) cmd_repair ;;
  version|--version|-v) echo "autotune v${VERSION}" ;;
  help|--help|-h|"") usage ;;
  *) echo "Unknown command: $COMMAND"; usage; exit 1 ;;
esac
